# DocuStay Frontend – copy to .env or .env.production. Do not commit .env.
# These are baked in at build time (npm run build). Match your backend .env / server.

# App origin (must match backend FRONTEND_BASE_URL / STRIPE_IDENTITY_RETURN_URL).
# No trailing slash. Examples: http://13.58.166.68  or  https://your-domain.com
# VITE_APP_ORIGIN=http://13.58.166.68

# API base URL. Use /api when the same server proxies /api to the backend (recommended).
# Use full URL only if the API is on a different host (e.g. https://api.your-domain.com).
# VITE_API_URL=/api

# Optional: for local dev proxy only (vite.config.ts). Defaults to http://127.0.0.1:8000 if unset.
# VITE_PROXY_TARGET=http://127.0.0.1:8000
