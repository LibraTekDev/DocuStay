# DocuStay – copy to .env and fill in values. Do not commit .env.

# Frontend (Vite) – Vite reads these from frontend/.env OR from this root .env (root is checked first).
# VITE_PROXY_TARGET: where the dev server proxies /api (e.g. http://127.0.0.1:8657 or http://127.0.0.1:8000).
# VITE_API_URL: backend URL for API/build (e.g. /api). Also used as proxy target if VITE_PROXY_TARGET is unset.
# VITE_APP_ORIGIN: frontend origin for Stripe return_url and invite links.
# VITE_PROXY_TARGET=http://127.0.0.1:8657
# VITE_API_URL=/api
# VITE_APP_ORIGIN=https://your-domain.com
# Optional: support email shown in Privacy Policy, Terms, Help Center, and contact UI (default: michael@docustay.online).
# VITE_SUPPORT_EMAIL=support@your-domain.com

# Database
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docustay_demo

# Auth
# JWT_SECRET_KEY=your-secret
# JWT_ALGORITHM=HS256

# Mailgun (required for verification emails and signup flow)
# Get the Private API key from Mailgun: Sending -> Domain -> API Keys (or Settings -> API Keys)
# MAILGUN_FROM_EMAIL must use your verified domain (e.g. noreply@librateksolutions.com), not a placeholder.
# Use https://api.eu.mailgun.net if your Mailgun account is in the EU region.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net
# Must be an address on your sending domain (e.g. noreply@docustay.com), or emails won't deliver.
# All app emails (verification, authority letters to providers, etc.) are sent FROM this DocuStay address, never from the owner.
MAILGUN_FROM_EMAIL=
MAILGUN_FROM_NAME=DocuStay

# Optional: SendGrid (used only if Mailgun is not set)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@docustay.demo
# SENDGRID_FROM_NAME=DocuStay

# Optional: Twilio for SMS
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_PHONE_NUMBER=

# Optional: Dropbox Sign for e-signatures
# DROPBOX_SIGN_API_KEY=
# DROPBOX_SIGN_CLIENT_ID=

# Stripe (Identity verification for owner/manager onboarding)
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# Create a Verification Flow in Stripe Dashboard → Identity → Flows; use its ID here
# STRIPE_IDENTITY_FLOW_ID=vf_...
# Property manager Identity flow (optional; used when creating identity session for property_manager role)
# STRIPE_IDENTITY_FLOW_ID_MANAGER=vf_1T9KEUEuCbp6yfL2hxIsrpAr
# Return URL after verification. MUST match your frontend origin (where localStorage has the token).
# Set to your app URL (e.g. same as VITE_APP_ORIGIN in frontend .env). No hardcoded localhost in code.
# STRIPE_IDENTITY_RETURN_URL=https://your-domain.com
# Optional: for logging invoice.paid in audit log. Developers → Webhooks → Add endpoint → Select invoice.paid → Signing secret (whsec_...)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Set to true to skip self-heal when listing billing (so after set_onboarding_invoice_unpaid.py the app stays "unpaid" for re-testing)
# STRIPE_SKIP_ONBOARDING_SELF_HEAL=false

# Utility Bucket (property registration: electric, gas, water, internet providers + authority letters)
# See docs/UTILITY_BUCKET.md and docs/UTILITY_API_KEYS.md.
# Rewiring America (electric+gas by ZIP): https://rewiring.link/api-signup
# REWIRING_AMERICA_API_KEY=
# Arcadia/Genability LSE (electric by ZIP, second source): https://dash.genability.com/signup → Create Application → appId + appKey
# ARCADIA_APP_ID=
# ARCADIA_APP_KEY=
# FCC National Broadband Map API (address-level internet): account at https://apps2.fcc.gov/fccUserReg, token at broadbandmap.fcc.gov → Manage API Access
# FCC_BROADBAND_API_USERNAME=   (your FCC login email)
# FCC_PUBLIC_MAP_DATA_APIS=    (API token from Manage API Access)
# EPA Envirofacts (water): no API key required; public API.
# Water fallback CSV (EPA SDWIS): optional; default project root CSV.csv (used by water_csv_job)
# WATER_CSV_PATH=
# Water SDWA bulk (EPA ECHO): optional; path to SDWA_PUB_WATER_SYSTEMS.csv or folder (e.g. SDWA_latest_downloads); used by sdwa_water_job
# WATER_SDWA_CSV_PATH=
# EIA: https://www.eia.gov/opendata/register.php (optional; scripts only)
# EIA_API_KEY=
# FCC BDC CSV path (fallback when API not used): optional; else auto-detect in project root or data/fcc/
# FCC_BROADBAND_CSV_PATH=
# Provider contact email lookup (scripts/find_provider_email.py): search web and extract emails from result pages.
# Use one of:
#   Brave: https://api.search.brave.com/ (dashboard may be api-dashboard.search.brave.com; if you get DNS_PROBE_FINISHED_NXDOMAIN, try another network or use SerpApi).
#   SerpApi (Google): https://serpapi.com/ – works when Brave dashboard is unreachable.
# BRAVE_SEARCH_API_KEY=
# SERPAPI_KEY=
# Max concurrent utility background jobs (provider contact lookup, pending verification); excess queued (default 2)
# UTILITY_BACKGROUND_JOBS_MAX_WORKERS=2
# Development only: test provider shown on Utilities tab and used when provider has no contact_email (see docs/TEST_PROVIDER_DEVELOPMENT.md). Do not set in production.
# TEST_PROVIDER_EMAIL=
# Base URL of frontend app for provider authority letter links in emails (e.g. https://app.docustay.com)
# FRONTEND_BASE_URL=

# Dead Man's Switch test mode: when true, DMS "lease end" is 2 minutes after invite acceptance (stay created_at). Use for testing only.
# Status Confirmation test mode: when true, effective "lease end" is 2 minutes after invite acceptance (stay created_at). Use for testing only.
# DMS_TEST_MODE=false
